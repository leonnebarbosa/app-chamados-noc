{
  "info": {
    "name": "NOC Chamados API",
    "description": "Coleção completa da API do sistema NOC Chamados v1.1.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.1.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://seu-dominio.com/api",
      "type": "string"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "🔐 Autenticação",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.test(\"Login bem-sucedido\", function () {",
                  "        pm.response.to.have.status(200);",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.success).to.eql(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@xmov.com.br\",\n  \"senha\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Usuário Atual (Me)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "🎫 Chamados",
      "item": [
        {
          "name": "Listar Chamados",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chamados?status=todos&impacto=todos",
              "host": ["{{baseUrl}}"],
              "path": ["chamados"],
              "query": [
                {
                  "key": "status",
                  "value": "todos"
                },
                {
                  "key": "impacto",
                  "value": "todos"
                },
                {
                  "key": "operadoraId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "popId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "busca",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Criar Chamado (Link)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoChamado\": \"link\",\n  \"linkId\": 1,\n  \"tipoFalhaId\": 1,\n  \"dataDeteccao\": \"{{$isoTimestamp}}\",\n  \"impacto\": \"critico\",\n  \"descricaoProblema\": \"Link fora do ar\",\n  \"protocoloOperadora\": \"INC123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chamados",
              "host": ["{{baseUrl}}"],
              "path": ["chamados"]
            }
          }
        },
        {
          "name": "Criar Chamado (Transporte)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoChamado\": \"transporte\",\n  \"transporteId\": 1,\n  \"tipoFalhaId\": 1,\n  \"dataDeteccao\": \"{{$isoTimestamp}}\",\n  \"impacto\": \"alto\",\n  \"descricaoProblema\": \"Perda de pacotes no transporte\",\n  \"protocoloOperadora\": \"INC789012\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chamados",
              "host": ["{{baseUrl}}"],
              "path": ["chamados"]
            }
          }
        },
        {
          "name": "Obter Chamado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/chamados/:id",
              "host": ["{{baseUrl}}"],
              "path": ["chamados", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Atualizar Chamado",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"em_atendimento\",\n  \"protocoloOperadora\": \"INC123456-UPD\",\n  \"descricao\": \"Status atualizado para em atendimento\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chamados/:id",
              "host": ["{{baseUrl}}"],
              "path": ["chamados", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Fechar Chamado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
