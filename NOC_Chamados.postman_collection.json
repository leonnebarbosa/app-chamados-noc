            "url": {
              "raw": "{{baseUrl}}/chamados/:id/fechar",
              "host": ["{{baseUrl}}"],
              "path": ["chamados", ":id", "fechar"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Deletar Chamado (Supervisor)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/chamados/:id",
              "host": ["{{baseUrl}}"],
