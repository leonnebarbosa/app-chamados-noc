# =================================
# Configurações do Banco de Dados
# =================================

# PostgreSQL (produção)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/noc_chamados?schema=public"

# SQLite (desenvolvimento local)
# DATABASE_URL="file:./dev.db"

# =================================
# Autenticação JWT
# =================================

# Chave secreta para tokens JWT (gere uma chave forte em produção!)
# Gerar: openssl rand -base64 32
JWT_SECRET="sua-chave-secreta-muito-forte-aqui-min-32-chars"

# =================================
# Configurações da Aplicação
# =================================

# Nome exibido no sistema
APP_NAME="NOC Chamados"

# URL base da aplicação (usado para links em emails, etc)
APP_URL="https://chamados.suaempresa.com.br"

# Ambiente (development | production)
NODE_ENV="production"

# =================================
# Configurações de SLA (em horas)
# =================================

SLA_CRITICO=4
SLA_ALTO=8
SLA_MEDIO=16
SLA_BAIXO=24

# Percentual do SLA para gerar alerta (70 = alerta quando atingir 70% do tempo)
SLA_ALERTA_PERCENTUAL=70

